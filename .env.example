# ============================================================
# Polymarket Trading Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's already in .gitignore)
# ============================================================

# --- Wallet Credentials ---
# Your Polygon wallet private key (starts with 0x...)
# WARNING: Anyone with this key controls your funds!
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Your Polymarket deposit wallet address (starts with 0x...)
# This is the wallet that holds your pUSD funds
POLYMARKET_FUNDER_ADDRESS=0x_your_deposit_wallet_address

# Signature type: 3 = POLY_1271 (deposit wallet, recommended for new users)
# 0 = EOA (MetaMask direct), 1 = Proxy, 2 = Safe
POLYMARKET_SIGNATURE_TYPE=3

# --- API Credentials ---
# These are derived from your wallet using setup_credentials.py
# Run: python setup_credentials.py
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Trading Mode ---
# Set ALL THREE to false for live trading with real money
PAPER_MODE=true
LIVE_TRADING_ENABLED=false
LIVE_DRY_RUN=true

# --- Capital ---
CAPITAL=100

# --- Live Order Limits ---
MAX_LIVE_ORDER_SIZE=10
MAX_LIVE_ORDERS_PER_CYCLE=2

# --- Risk Constraints (as fraction of capital) ---
MAX_EXPOSURE=0.75
MAX_POSITION=0.20
MAX_DRAWDOWN=0.15
MIN_BET_SIZE=0.02

# --- Category Exposure Limits ---
CRYPTO=0.30
POLITICS=0.25
SPORTS=0.20
SCIENCE=0.15
DEFAULT_LIMIT=0.25